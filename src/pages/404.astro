---
import Base from '@/layouts/Base.astro';
import Button from '@/components/ui/Button.astro';
---

<Base title="Page Not Found — GovModern">
  <section class="bg-gov-navy section-padding min-h-96 flex items-center">
    <div class="container-max text-center">
      <p class="text-gov-gold text-8xl font-bold mb-4" aria-hidden="true">404</p>
      <h1 class="text-3xl font-bold text-white mb-4">Page Not Found</h1>
      <p class="text-white/70 mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <Button href="/" variant="primary">
        ← Back to Home
      </Button>
    </div>
  </section>
</Base>
