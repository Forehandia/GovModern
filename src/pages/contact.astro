---
import Base from '@/layouts/Base.astro';
import ContactForm from '@/components/sections/ContactForm.astro';
---

<Base
  title="Contact — GovModern"
  description="Get in touch with GovModern to discuss your agency's .NET modernization and cloud migration needs."
>
  <section class="bg-gov-navy py-16 px-4">
    <div class="container-max">
      <p class="text-gov-gold text-sm font-semibold uppercase tracking-widest mb-3">Contact Us</p>
      <h1 class="text-4xl font-bold text-white mb-4">Let's Talk Modernization</h1>
      <p class="text-white/70 max-w-xl leading-relaxed">
        Whether you're just beginning to scope a modernization effort or need a partner for an active procurement, we're here to help.
      </p>
    </div>
  </section>

  <ContactForm />
</Base>
