---
import Base from '@/layouts/Base.astro';
---

<Base
  title="Privacy Policy — GovModern"
  description="GovModern privacy policy — how we handle information submitted through our website."
>
  <section class="bg-gov-navy py-16 px-4">
    <div class="container-max">
      <h1 class="text-4xl font-bold text-white">Privacy Policy</h1>
      <p class="text-white/60 mt-2 text-sm">Last updated: March 2026</p>
    </div>
  </section>

  <section class="bg-gov-light section-padding">
    <div class="container-max max-w-3xl prose prose-slate">
      <h2 class="text-gov-navy">Information We Collect</h2>
      <p class="text-gov-slate">
        We collect information you voluntarily submit through our contact form: your name, work email address, phone number (optional), agency or organization name, and your message.
      </p>

      <h2 class="text-gov-navy">How We Use Your Information</h2>
      <p class="text-gov-slate">
        We use submitted information solely to respond to your inquiry. We do not sell, share, rent, or trade your personal information with third parties for marketing purposes.
      </p>

      <h2 class="text-gov-navy">Data Storage</h2>
      <p class="text-gov-slate">
        Contact form submissions are transmitted via email to our internal team. We do not maintain a database of contact form submissions. Emails are retained according to standard business retention practices.
      </p>

      <h2 class="text-gov-navy">Cookies and Tracking</h2>
      <p class="text-gov-slate">
        This website does not use tracking cookies, analytics scripts, or third-party advertising. We do not collect any data about your browsing behavior.
      </p>

      <h2 class="text-gov-navy">Security</h2>
      <p class="text-gov-slate">
        This site is hosted on Azure Static Web Apps with HTTPS enforced. All data in transit is encrypted via TLS.
      </p>

      <h2 class="text-gov-navy">Contact</h2>
      <p class="text-gov-slate">
        Questions about this privacy policy? Email us at <a href="mailto:contact@govmodern.com" class="text-gov-blue hover:text-gov-navy">contact@govmodern.com</a>.
      </p>
    </div>
  </section>
</Base>
