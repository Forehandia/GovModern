---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  center?: boolean;
  light?: boolean;
  id?: string;
}

const { eyebrow, title, subtitle, center = false, light = false, id } = Astro.props;
---

<div class:list={['mb-12', center && 'text-center']}>
  {eyebrow && (
    <p class:list={[
      'text-sm font-semibold uppercase tracking-widest mb-3',
      light ? 'text-gov-gold' : 'text-gov-blue',
    ]}>
      {eyebrow}
    </p>
  )}
  <h2 id={id} class:list={[
    'text-3xl sm:text-4xl font-bold leading-tight',
    light ? 'text-white' : 'text-gov-navy',
  ]}>
    {title}
  </h2>
  {subtitle && (
    <p class:list={[
      'mt-4 text-lg leading-relaxed max-w-3xl',
      center && 'mx-auto',
      light ? 'text-white/75' : 'text-gov-slate',
    ]}>
      {subtitle}
    </p>
  )}
</div>
