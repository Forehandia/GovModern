---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  type?: 'button' | 'submit';
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: extraClass = '',
  type = 'button',
} = Astro.props;

const base = 'inline-flex items-center gap-2 font-semibold rounded transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gov-gold focus-visible:ring-offset-2';

const variants = {
  primary: 'bg-gov-gold hover:bg-gov-gold/90 text-white',
  secondary: 'bg-gov-blue hover:bg-gov-blue/90 text-white',
  outline: 'border-2 border-white text-white hover:bg-white hover:text-gov-navy',
};

const sizes = {
  sm: 'text-sm px-4 py-2',
  md: 'text-base px-6 py-3',
  lg: 'text-lg px-8 py-4',
};

const classes = [base, variants[variant], sizes[size], extraClass].join(' ');
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
