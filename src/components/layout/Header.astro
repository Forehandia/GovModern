---
const navLinks = [
  { href: '/services', label: 'Services' },
  { href: '/#why-us', label: 'Why GovModern' },
  { href: '/#compliance', label: 'Compliance' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-gov-navy/95 backdrop-blur-sm border-b border-white/10">
  <div class="container-max">
    <div class="flex items-center justify-between h-16 px-4 sm:px-6 lg:px-8">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="GovModern home">
        <div class="w-8 h-8 bg-gov-gold rounded flex items-center justify-center">
          <span class="text-white font-bold text-sm">GM</span>
        </div>
        <span class="text-white font-semibold text-lg tracking-tight">GovModern</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-white/80 hover:text-white text-sm font-medium transition-colors"
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA + mobile toggle -->
      <div class="flex items-center gap-4">
        <a
          href="/contact"
          class="hidden sm:inline-flex items-center gap-2 bg-gov-gold hover:bg-gov-gold/90 text-white text-sm font-semibold px-4 py-2 rounded transition-colors"
        >
          Get in Touch
          <span aria-hidden="true">→</span>
        </a>

        <!-- Mobile hamburger (CSS-only) -->
        <label
          for="mobile-menu-toggle"
          class="md:hidden cursor-pointer p-2 text-white/80 hover:text-white"
          aria-label="Toggle navigation menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </label>
      </div>
    </div>

    <!-- Mobile nav (CSS-only toggle using hidden checkbox) -->
    <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" aria-hidden="true" />
    <nav
      class="hidden peer-checked:block md:hidden border-t border-white/10 py-4 px-4"
      aria-label="Mobile navigation"
    >
      <ul class="flex flex-col gap-4">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block text-white/80 hover:text-white text-sm font-medium transition-colors py-1"
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 bg-gov-gold hover:bg-gov-gold/90 text-white text-sm font-semibold px-4 py-2 rounded transition-colors mt-2"
          >
            Get in Touch →
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16" aria-hidden="true"></div>
