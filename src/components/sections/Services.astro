---
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Card from '@/components/ui/Card.astro';
import { services } from '@/data/services';

// SVG icon paths by key
const icons: Record<string, string> = {
  refresh: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  cloud: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
  api: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  'check-badge': 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
  chart: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
};
---

<section id="services" class="bg-gov-light section-padding" aria-labelledby="services-heading">
  <div class="container-max">
    <SectionHeader
      eyebrow="What We Do"
      title="End-to-End .NET Modernization"
      subtitle="From legacy assessment to cloud-native delivery, we cover every phase of the modernization lifecycle — with deep expertise in the compliance requirements that govern state and local government systems."
      id="services-heading"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <Card>
          <!-- Icon -->
          <div class="w-12 h-12 bg-gov-blue/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-gov-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[service.icon]} />
            </svg>
          </div>

          <h3 class="text-gov-navy font-semibold text-lg mb-3">{service.title}</h3>
          <p class="text-gov-slate text-sm leading-relaxed mb-4">{service.description}</p>

          <a
            href={`/services#${service.id}`}
            class="text-gov-blue text-sm font-medium hover:text-gov-navy transition-colors inline-flex items-center gap-1"
            aria-label={`Learn more about ${service.title}`}
          >
            Learn more →
          </a>
        </Card>
      ))}
    </div>
  </div>
</section>
